  "runs": [
    {
      "name": "example_small",
      "topology": "temp/small_topo3.txt",
      "ppp": 1000,
      "seed": 0,
      "vc": 8,
      "analyses": [
        {
          "script": "scripts/analyze_pathlog.py",
          "inputs": ["{pathlog}"]
        }
      ]
    }
  ]
}
