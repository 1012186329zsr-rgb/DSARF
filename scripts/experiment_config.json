{
  "default_binary": "bin/main",
  "default_vc": 8,
  "default_ppp": 1000,
  "default_packet_num": 1,
  "arg_template": "{topo} 0 0 0 {ppp} {seed} 0 0 0 {pathlog} {traffic} {vc}",
  "default_analyses": [
    {
      "script": "scripts/analyze_pathlog.py",
      "inputs": ["{pathlog}"]
